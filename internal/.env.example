# ============================================================
# ClawAPI VPS — 環境變數範本
# 複製此檔案為 .env 並填入實際值
# ============================================================

# ─── 服務埠號 ───
VPS_PORT=3100

# ─── 執行環境 ───
NODE_ENV=production

# ─── 管理員 Token（必填：用於 /admin/* 端點認證）───
# 請用隨機產生的強密碼，例如：openssl rand -base64 32
ADMIN_TOKEN=<generate-random-token>

# ─── Telegram 通知（選填：異常告警推送）───
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── GitHub 整合（選填：Release 通知、Adapter PR 審核）───
GITHUB_TOKEN=
GITHUB_REPO=clawapi/clawapi

# ─── 資料庫路徑（Docker 內路徑）───
DB_PATH=/data/clawapi-vps.db

# ─── ECDH 金鑰目錄（裝置認證用）───
ECDH_KEY_DIR=/keys/ecdh
