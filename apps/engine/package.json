{
  "name": "@clawapi/engine",
  "version": "0.1.4",
  "description": "Open-source AI API Key Manager + Smart Router. Manage multiple AI provider keys and route requests intelligently.",
  "keywords": ["ai", "api", "openai", "anthropic", "gemini", "router", "proxy", "mcp", "claude-code"],
  "homepage": "https://github.com/sstklen/clawapi",
  "repository": {
    "type": "git",
    "url": "https://github.com/sstklen/clawapi.git"
  },
  "main": "src/index.ts",
  "types": "src/index.ts",
  "bin": {
    "clawapi": "./bin/clawapi.js"
  },
  "files": [
    "bin/**/*",
    "src/**/*.ts",
    "src/adapters/schemas/**/*.yaml",
    "config/**/*",
    "locales/**/*",
    "package.json",
    "tsconfig.json"
  ],
  "scripts": {
    "dev": "bun run src/index.ts",
    "typecheck": "bunx tsc --noEmit",
    "test": "bun test",
    "build": "bun run scripts/build.ts",
    "build:current": "bun build src/cli/index.ts --compile --outfile dist/clawapi"
  },
  "dependencies": {
    "@clawapi/protocol": "0.1.0",
    "hono": "^4.0.0",
    "js-yaml": "^4.1.1"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "license": "AGPL-3.0",
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "bun-types": "^1.3.10"
  }
}
