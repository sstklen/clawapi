{
  "name": "@clawapi/engine",
  "version": "0.1.0",
  "description": "ClawAPI 開源 AI API 管理引擎",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "bin": {
    "clawapi": "./src/cli/index.ts"
  },
  "files": [
    "src/**/*.ts",
    "config/**/*",
    "locales/**/*",
    "dist/**/*",
    "package.json",
    "tsconfig.json"
  ],
  "scripts": {
    "dev": "bun run src/index.ts",
    "typecheck": "bunx tsc --noEmit",
    "test": "bun test",
    "build": "bun run scripts/build.ts",
    "build:current": "bun build src/cli/index.ts --compile --outfile dist/clawapi"
  },
  "dependencies": {
    "@clawapi/protocol": "workspace:*",
    "hono": "^4.0.0",
    "js-yaml": "^4.1.1"
  },
  "license": "AGPL-3.0",
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "bun-types": "^1.3.10"
  }
}
